# Puerto del servidor
PRINT_SERVER_PORT=9123

# Impresora (CUPS / Windows)
PRINTER_NAME=MHT58

# Linux RAW (opcional si no usas CUPS)
# PRINTER_DEVICE=/dev/usb/lp0

# Charset recomendado para impresora 58mm (tildes correctas)
PRINTER_DISABLE_CHINESE_MODE=true
PRINTER_INTERNATIONAL=3
PRINTER_CODEPAGE=19
PRINTER_CHARSET_MAP=cp858

# Modo autónomo (Camino A)
# No configurar manualmente - se genera automáticamente al vincular con POST /pair
# Las credenciales se guardan en .vendy-credentials.json
# SUPABASE_URL se usa solo si no hay credenciales guardadas
# SUPABASE_URL=

# Seguridad (P0.3)
# API key para autenticar requests (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PRINT_API_KEY=
# Origenes permitidos (separados por coma). Ajustar al dominio de tu app.
PRINT_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
# Limite de requests por minuto por IP
PRINT_RATE_LIMIT=30
